{
  "name": "polri-bwc-command-center",
  "version": "1.0.0",
  "description": "Electron desktop wrapper for Polri BWC Command Center dashboard.",
  "main": "main.js",
  "author": "Senopati",
  "license": "UNLICENSED",
  "scripts": {
    "prepare:assets": "node scripts/generate-icons.mjs",
    "postinstall": "npm run prepare:assets",
    "start": "npm run prepare:assets && electron .",
    "dist:win": "npm run prepare:assets && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.asksenopati.polribwc.commandcenter",
    "productName": "Polri BWC Command Center",
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "assets/**/*",
      "build/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Polri-BWC-Command-Center-Setup-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.2"
  }
}
